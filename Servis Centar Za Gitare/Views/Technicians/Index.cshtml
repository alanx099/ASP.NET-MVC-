@model IEnumerable<ZapTehnicar>
@{
    ViewData["Title"] = "Technicians";
    var pendingSkillNeeds = ViewData["PendingSkillNeeds"] as IEnumerable<PendingSkillNeedViewModel> ?? Enumerable.Empty<PendingSkillNeedViewModel>();
    var pendingSkillNeedCount = pendingSkillNeeds.Sum(item => item.Count);
    var repairCounts = ViewData["TechnicianRepairCounts"] as IDictionary<long, int> ?? new Dictionary<long, int>();
    var listState = ViewData["ListState"] as ListStateViewModel;
}

<section class="hero-panel">
    <p class="hero-kicker">Technician roster</p>
    <h1 class="hero-title">Technicians</h1>
    <p class="hero-subtitle">Skilled repair specialists displayed as premium profile cards with their knowledge areas and service context.</p>
    <div class="hero-actions">
        <a class="action-link primary" asp-action="Create">Add technician</a>
        @if (pendingSkillNeedCount > 0)
        {
            <button class="action-link secondary gc-alert-toggle" type="button" data-pending-skills-toggle aria-expanded="false" aria-controls="pending-skills-panel">
                <span class="gc-alert-icon" aria-hidden="true">!</span>
                <span>@pendingSkillNeedCount pending skill @(pendingSkillNeedCount == 1 ? "need" : "needs")</span>
            </button>
        }
    </div>
</section>

@if (pendingSkillNeedCount > 0)
{
    <section class="detail-card gc-pending-skills" id="pending-skills-panel" data-pending-skills-panel hidden>
        <div class="detail-head">
            <div>
                <p class="section-label">Hiring or training needed</p>
                <h2 class="section-title">Skills required to start received repairs</h2>
                <p class="section-copy">Add a technician with these skills or edit an existing technician so the waiting repair orders can move forward.</p>
            </div>
        </div>
        <div class="tag-row">
            @foreach (var need in pendingSkillNeeds)
            {
                <span class="tag-chip">@need.TipGitareName / @need.VrstaPopravkaName (@need.Count)</span>
            }
        </div>
    </section>
}

@if (listState != null)
{
    @await Html.PartialAsync("_ListControls", listState)
}

<section class="entity-grid">
    @foreach (var technician in Model)
    {
        var repairCount = repairCounts.TryGetValue(technician.Id, out var repairs) ? repairs : 0;

        <article class="entity-card" data-delete-card>
            <div class="entity-head">
                <div class="brand" style="align-items:flex-start;">
                    <span class="profile-badge">@(technician.Ime.Substring(0, 1) + technician.Prezime.Substring(0, 1))</span>
                    <div>
                        <h2 class="entity-title">@technician.Ime @technician.Prezime</h2>
                        <p class="entity-subtitle">@technician.Email</p>
                    </div>
                </div>
                <span class="status-chip success">@technician.Znanja.Count skills</span>
            </div>

            <div class="entity-body">
                <div class="badge-row">
                    <span class="info-chip">@technician.BrojTelefona</span>
                    <span class="info-chip" data-gc-date-display="@technician.DatumZaposlenja">@technician.DatumZaposlenja</span>
                    <span class="info-chip">@technician.Placa.ToString("C0")</span>
                    @if (repairCount > 0)
                    {
                        <span class="info-chip">@repairCount assigned repairs</span>
                    }
                </div>
                <div class="tag-row">
                    @foreach (var skill in technician.Znanja)
                    {
                        <span class="tag-chip">@skill.TipGitare?.Naziv / @skill.VrstaPopravka?.Naziv</span>
                    }
                </div>
                <div class="queue-footer">
                    <a class="action-btn" asp-action="Details" asp-route-id="@technician.Id">View technician details</a>
                    <a class="action-btn secondary" asp-action="Edit" asp-route-id="@technician.Id">Edit technician</a>
                    <form asp-action="Delete" asp-route-id="@technician.Id" method="post" data-delete-form data-delete-label="@technician.Ime @technician.Prezime">
                        @Html.AntiForgeryToken()
                        <button class="action-btn danger" type="submit" title="Delete technician">Delete</button>
                    </form>
                </div>
            </div>
        </article>
    }
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_LoadMore", listState)
}

@section Scripts {
    <script>
        (function () {
            const toggle = document.querySelector("[data-pending-skills-toggle]");
            const panel = document.querySelector("[data-pending-skills-panel]");

            if (!toggle || !panel) {
                return;
            }

            toggle.addEventListener("click", function () {
                const isOpen = toggle.getAttribute("aria-expanded") === "true";
                toggle.setAttribute("aria-expanded", (!isOpen).toString());
                panel.hidden = isOpen;
            });
        })();
    </script>
}

@model IEnumerable<Stranka>
@{
    ViewData["Title"] = "Customers";
    var guitarCounts = ViewData["CustomerGuitarCounts"] as IDictionary<long, int> ?? new Dictionary<long, int>();
    var repairCounts = ViewData["CustomerRepairCounts"] as IDictionary<long, int> ?? new Dictionary<long, int>();
    var listState = ViewData["ListState"] as ListStateViewModel;
}

<section class="hero-panel">
    <p class="hero-kicker">Customer directory</p>
    <h1 class="hero-title">Customers</h1>
    <p class="hero-subtitle">A premium contact roster with relationship context, guitar counts, and quick access to each customer dossier.</p>
    <div class="hero-actions">
        <a class="action-link primary" asp-action="Create">Add customer</a>
    </div>
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_ListControls", listState)
}

<section class="entity-grid">
    @foreach (var customer in Model)
    {
        var guitarCount = guitarCounts.TryGetValue(customer.Id, out var guitars) ? guitars : 0;
        var repairCount = repairCounts.TryGetValue(customer.Id, out var repairs) ? repairs : 0;
        var canDelete = guitarCount == 0 && repairCount == 0;
        var deleteTitle = canDelete
            ? "Delete customer"
            : "Customer cannot be deleted while they have guitars or repair orders.";

        <article class="entity-card" data-delete-card>
            <div class="entity-head">
                <div class="brand" style="align-items:flex-start;">
                    <span class="profile-badge">@(customer.Ime.Substring(0, 1) + customer.Prezime.Substring(0, 1))</span>
                    <div>
                        <h2 class="entity-title">@customer.Ime @customer.Prezime</h2>
                        <p class="entity-subtitle">@customer.Email</p>
                    </div>
                </div>
                <span class="status-chip info">@guitarCount guitars</span>
            </div>

            <div class="entity-body">
                <div class="badge-row">
                    <span class="info-chip">@customer.BrojTelefona</span>
                    <span class="info-chip" data-gc-date-display="@customer.DatumRegistracije">@customer.DatumRegistracije</span>
                </div>
                <p class="section-copy">@customer.Napomena</p>
                <div class="queue-footer">
                    <a class="action-btn" asp-action="Details" asp-route-id="@customer.Id">View customer details</a>
                    <a class="action-btn secondary" asp-action="Edit" asp-route-id="@customer.Id">Edit customer</a>
                    <form asp-action="Delete" asp-route-id="@customer.Id" method="post" data-delete-form data-delete-label="@customer.Ime @customer.Prezime">
                        @Html.AntiForgeryToken()
                        <button class="action-btn danger" type="submit" title="@deleteTitle" @(canDelete ? null : "disabled")>Delete</button>
                    </form>
                </div>
            </div>
        </article>
    }
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_LoadMore", listState)
}

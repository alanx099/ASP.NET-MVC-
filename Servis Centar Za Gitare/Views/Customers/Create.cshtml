@model Servis_Centar_Za_Gitare.ViewModels.CustomerCreateViewModel

@{
    ViewData["Title"] = "New Customer";
}

<h2 class="section-title">New Customer</h2>

<form asp-action="Create" method="post" class="gc-form" novalidate>
    @Html.AntiForgeryToken()
    <div class="gc-card--form">
    <div class="form-group gc-form-group">
        <label asp-for="Customer.Ime" class="gc-label">First Name</label>
        <input asp-for="Customer.Ime" class="form-control gc-input" aria-describedby="Customer_Ime-error" />
        <span asp-validation-for="Customer.Ime" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Customer.Prezime" class="gc-label">Last Name</label>
        <input asp-for="Customer.Prezime" class="form-control gc-input" aria-describedby="Customer_Prezime-error" />
        <span asp-validation-for="Customer.Prezime" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Customer.Email" class="gc-label">Email</label>
        <input asp-for="Customer.Email" class="form-control gc-input" aria-describedby="Customer_Email-error" />
        <span asp-validation-for="Customer.Email" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Customer.BrojTelefona" class="gc-label">Phone Number</label>
        <input asp-for="Customer.BrojTelefona" class="form-control gc-input" aria-describedby="Customer_BrojTelefona-error" />
        <span asp-validation-for="Customer.BrojTelefona" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Customer.Adresa" class="gc-label">Address</label>
        <input asp-for="Customer.Adresa" class="form-control gc-input" aria-describedby="Customer_Adresa-error" />
        <span asp-validation-for="Customer.Adresa" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel("Customer.DatumRegistracije", "Registration Date", Model.Customer.DatumRegistracije, maxFutureDays: 1, maxFutureMessage: "Registration date cannot be more than one day in the future."))

    <div class="form-group gc-form-group">
        <label class="gc-label" for="add-guitar-toggle">Add a guitar for this customer</label>
        <input id="add-guitar-toggle" asp-for="AddGuitar" type="checkbox" />
    </div>

    <section id="new-guitar-section" style="display:none; border-top:1px solid rgba(255,255,255,.15); margin-top:1rem; padding-top:1rem;">
        <h3 class="section-title" style="margin-top:0;">New Guitar</h3>
        <div class="form-group gc-form-group">
            <label asp-for="GuitarSerijskiBroj" class="gc-label">Serial Number</label>
            <input asp-for="GuitarSerijskiBroj" class="form-control gc-input" aria-describedby="GuitarSerijskiBroj-error" />
            <span asp-validation-for="GuitarSerijskiBroj" class="invalid-feedback" role="alert" aria-live="polite"></span>
        </div>
        @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.GuitarMarkaId), "Brand", Url.Action("AutocompleteBrands", "Guitars")!, Model.GuitarMarkaId.HasValue ? Model.GuitarMarkaId.Value : null, ViewData["SelectedGuitarBrandText"]?.ToString(), "GuitarMarkaId-error") { Placeholder = "Search brand..." })
        <div class="form-group gc-form-group">
            <label asp-for="GuitarBrojZica" class="gc-label">Number of Strings</label>
            <input asp-for="GuitarBrojZica" class="form-control gc-input" aria-describedby="GuitarBrojZica-error" />
            <span asp-validation-for="GuitarBrojZica" class="invalid-feedback" role="alert" aria-live="polite"></span>
        </div>
        <div class="form-group gc-form-group">
            <label asp-for="GuitarTipGitareId" class="gc-label">Guitar Type</label>
            <div class="gc-select">
                <select asp-for="GuitarTipGitareId" class="form-control gc-input" asp-items="Model.TipoviGitare" data-gc-select="true" aria-describedby="GuitarTipGitareId-error">
                    <option value="">Select guitar type</option>
                </select>
            </div>
            <span asp-validation-for="GuitarTipGitareId" class="invalid-feedback" role="alert" aria-live="polite"></span>
        </div>
        @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel(nameof(Model.GuitarDatumZaprimanja), "Received Date", Model.GuitarDatumZaprimanja, false, maxFutureDays: 1, maxFutureMessage: "Received date cannot be more than one day in the future."))
    </section>

    <div class="form-group gc-form-group">
        <label asp-for="Customer.Napomena" class="gc-label">Notes</label>
        <textarea asp-for="Customer.Napomena" class="form-control gc-input" aria-describedby="Customer_Napomena-error"></textarea>
        <span asp-validation-for="Customer.Napomena" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="gc-actions">
        <button type="submit" class="btn gc-btn-primary">Create</button>
        <a asp-action="Index" class="btn gc-btn-secondary">Cancel</a>
    </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const toggle = document.getElementById("add-guitar-toggle");
            const section = document.getElementById("new-guitar-section");
            if (!toggle || !section) {
                return;
            }

            const sync = function () {
                section.style.display = toggle.checked ? "block" : "none";
            };

            toggle.addEventListener("change", sync);
            sync();
        })();
    </script>
}

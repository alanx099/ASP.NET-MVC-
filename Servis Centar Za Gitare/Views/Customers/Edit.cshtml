@model Servis_Centar_Za_Gitare.models.Stranka

@{
    ViewData["Title"] = "Edit Customer";
}

<h2 class="section-title">Edit Customer</h2>

<form asp-action="Edit" method="post" class="gc-form" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="gc-card--form">
    <div class="form-group gc-form-group">
        <label asp-for="Ime" class="gc-label">First Name</label>
        <input asp-for="Ime" class="form-control gc-input" aria-describedby="Ime-error" />
        <span asp-validation-for="Ime" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Prezime" class="gc-label">Last Name</label>
        <input asp-for="Prezime" class="form-control gc-input" aria-describedby="Prezime-error" />
        <span asp-validation-for="Prezime" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Email" class="gc-label">Email</label>
        <input asp-for="Email" class="form-control gc-input" aria-describedby="Email-error" />
        <span asp-validation-for="Email" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="BrojTelefona" class="gc-label">Phone Number</label>
        <input asp-for="BrojTelefona" class="form-control gc-input" aria-describedby="BrojTelefona-error" />
        <span asp-validation-for="BrojTelefona" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="Adresa" class="gc-label">Address</label>
        <input asp-for="Adresa" class="form-control gc-input" aria-describedby="Adresa-error" />
        <span asp-validation-for="Adresa" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel(nameof(Model.DatumRegistracije), "Registration Date", Model.DatumRegistracije, maxFutureDays: 1, maxFutureMessage: "Registration date cannot be more than one day in the future."))
    <div class="gc-actions">
        <button type="submit" class="btn gc-btn-primary">Save</button>
        <a asp-action="Index" class="btn gc-btn-secondary">Cancel</a>
    </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model RepairDetailsViewModel
@{
    ViewData["Title"] = "Repair Details";
    var chipClass = Model.Repair.StatusNaloga?.Id switch
    {
        4 => "success",
        5 => "danger",
        3 => "warning",
        2 => "info",
        _ => "info"
    };
}

<section class="hero-panel">
    <p class="hero-kicker">Repair dossier</p>
    <h1 class="hero-title">@Model.Repair.VrstaPopravka?.Naziv</h1>
    <p class="hero-subtitle">@Model.Repair.OpisKvara</p>
    <div class="hero-actions">
        <span class="status-chip @chipClass">@Model.Repair.StatusNaloga?.Naziv</span>
        <span class="status-chip info" data-gc-date-display="@Model.Repair.DatumOtvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.Repair.DatumOtvaranja.ToString("dd MMM yyyy")</span>
        <span class="status-chip success" data-gc-date-display="@Model.Repair.DatumZatvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.Repair.DatumZatvaranja.ToString("dd MMM yyyy")</span>
        <a class="action-link primary" asp-controller="Repairs" asp-action="Edit" asp-route-id="@Model.Repair.Id">Edit repair</a>
        <a class="action-link secondary" asp-controller="Repairs" asp-action="Index">Back to repairs</a>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card">
        <h3>Repair timeline</h3>
        <dl class="definition-list">
            <div><dt>Opened</dt><dd data-gc-date-display="@Model.Repair.DatumOtvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.Repair.DatumOtvaranja.ToString("dd MMM yyyy")</dd></div>
            <div><dt>Planned close</dt><dd data-gc-date-display="@Model.Repair.DatumZatvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.Repair.DatumZatvaranja.ToString("dd MMM yyyy")</dd></div>
            <div><dt>Status</dt><dd>@Model.Repair.StatusNaloga?.Naziv</dd></div>
            <div><dt>Description</dt><dd>@Model.Repair.OpisKvara</dd></div>
        </dl>
    </article>

    <article class="detail-card">
        <h3>Related records</h3>
        <div class="meta-grid">
            <div class="meta-card">
                <h3>Customer</h3>
                @if (Model.Customer != null)
                {
                    <p class="meta-value">@Model.Customer.Ime @Model.Customer.Prezime</p>
                    <a class="action-btn" asp-controller="Customers" asp-action="Details" asp-route-id="@Model.Customer.Id">Open customer</a>
                }
            </div>
            <div class="meta-card">
                <h3>Guitar</h3>
                @if (Model.Guitar != null)
                {
                    <p class="meta-value">@Model.Guitar.Marka @Model.Guitar.SerijskiBroj</p>
                    <a class="action-btn" asp-controller="Guitars" asp-action="Details" asp-route-id="@Model.Guitar.Id">Open guitar</a>
                }
            </div>
            <div class="meta-card">
                <h3>Technician</h3>
                @if (Model.Technician != null)
                {
                    <p class="meta-value">@Model.Technician.Ime @Model.Technician.Prezime</p>
                    <a class="action-btn" asp-controller="Technicians" asp-action="Details" asp-route-id="@Model.Technician.Id">Open technician</a>
                }
                else
                {
                    <p class="meta-value">Unassigned</p>
                    <p class="section-copy">No technician currently has the required skill for this repair.</p>
                }
            </div>
        </div>
    </article>
</section>

@model Servis_Centar_Za_Gitare.models.Nalog

@{
    ViewData["Title"] = "New Repair";
    var gitare = ViewData["Gitare"] as SelectList;
    var stranke = ViewData["Stranke"] as SelectList;
    var tehnicari = ViewData["Tehnicari"] as SelectList;
    var statusiNaloga = ViewData["StatusiNaloga"] as SelectList;
    var vrstePopravke = ViewData["VrstePopravke"] as SelectList;
}

<h2>New Repair</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="GitaraId"></label>
        <select asp-for="GitaraId" class="form-control" asp-items="gitare"></select>
        <span asp-validation-for="GitaraId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="StrankaId"></label>
        <select asp-for="StrankaId" class="form-control" asp-items="stranke"></select>
        <span asp-validation-for="StrankaId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="TehnicarId"></label>
        <select asp-for="TehnicarId" class="form-control" asp-items="tehnicari"></select>
        <span asp-validation-for="TehnicarId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="VrstaPopravkaId"></label>
        <select asp-for="VrstaPopravkaId" class="form-control" asp-items="vrstePopravke"></select>
        <span asp-validation-for="VrstaPopravkaId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="StatusNalogaId"></label>
        <select asp-for="StatusNalogaId" class="form-control" asp-items="statusiNaloga"></select>
        <span asp-validation-for="StatusNalogaId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="OpisKvara"></label>
        <textarea asp-for="OpisKvara" class="form-control"></textarea>
        <span asp-validation-for="OpisKvara" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DatumOtvaranja"></label>
        <input asp-for="DatumOtvaranja" class="form-control" />
        <span asp-validation-for="DatumOtvaranja" class="text-danger"></span>
    </div>
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
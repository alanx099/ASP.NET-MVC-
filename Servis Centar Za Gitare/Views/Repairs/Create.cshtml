@model Servis_Centar_Za_Gitare.models.Nalog

@{
    ViewData["Title"] = "New Repair";
    var statusiNaloga = ViewData["StatusiNaloga"] as SelectList;
}

<h2 class="section-title">New Repair</h2>

<form asp-action="Create" method="post" class="gc-form" novalidate data-repair-form>
    @Html.AntiForgeryToken()
    <div class="gc-card--form">
    @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.StrankaId), "Customer", Url.Action("AutocompleteCustomers", "Repairs")!, Model.StrankaId > 0 ? Model.StrankaId : null, ViewData["SelectedCustomerText"]?.ToString(), "StrankaId-error") { Placeholder = "Search customer..." })
    @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.GitaraId), "Guitar", Url.Action("AutocompleteGuitars", "Repairs")!, Model.GitaraId > 0 ? Model.GitaraId : null, ViewData["SelectedGuitarText"]?.ToString(), "GitaraId-error") { Placeholder = "Search guitar...", CustomerField = "#StrankaId" })
    @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.TehnicarId), "Technician", Url.Action("AutocompleteTechnicians", "Repairs")!, Model.TehnicarId, ViewData["SelectedTechnicianText"]?.ToString(), "TehnicarId-error") { Placeholder = "Search technician...", GuitarField = "#GitaraId", RepairTypeField = "#VrstaPopravkaId" })
    @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.VrstaPopravkaId), "Repair Type", Url.Action("AutocompleteRepairTypes", "Repairs")!, Model.VrstaPopravkaId > 0 ? Model.VrstaPopravkaId : null, ViewData["SelectedRepairTypeText"]?.ToString(), "VrstaPopravkaId-error") { Placeholder = "Search repair type..." })
    <div class="form-group gc-form-group">
        <label asp-for="OpisKvara" class="gc-label">Description of Issue</label>
        <textarea asp-for="OpisKvara" class="form-control gc-input" aria-describedby="OpisKvara-error"></textarea>
        <span asp-validation-for="OpisKvara" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel(nameof(Model.DatumOtvaranja), "Opening Date", Model.DatumOtvaranja))
    <div class="form-group gc-form-group">
        <label asp-for="StatusNalogaId" class="gc-label">Status</label>
        <div class="gc-select">
            <select asp-for="StatusNalogaId" class="form-control gc-input" asp-items="statusiNaloga" data-gc-select="true" aria-describedby="StatusNalogaId-error">
                <option value="">Select status</option>
            </select>
        </div>
        <span asp-validation-for="StatusNalogaId" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="gc-actions">
        <button type="submit" class="btn gc-btn-primary">Create</button>
        <a asp-action="Index" class="btn gc-btn-secondary">Cancel</a>
    </div>
    </div>
</form>

<div class="gc-modal" id="repair-skill-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="repair-skill-modal-title">
    <div class="gc-modal__panel">
        <p class="section-label">Technician skill check</p>
        <h3 class="gc-modal__title" id="repair-skill-modal-title" data-repair-skill-title>Missing required skill</h3>
        <p class="section-copy" data-repair-skill-message>The selected technician does not have the skill required for this guitar type and repair type. Choose another technician or repair type before saving.</p>
        <div class="gc-actions">
            <button type="button" class="btn gc-btn-primary" data-repair-skill-close>Review repair</button>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script type="application/json" id="repair-skill-data">@Html.Raw(ViewData["RepairSkillCheck"])</script>
    <script src="~/js/gc-repair-skill.js" asp-append-version="true"></script>
}

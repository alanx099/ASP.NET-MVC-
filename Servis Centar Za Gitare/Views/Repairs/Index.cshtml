@model IEnumerable<RepairQueueItemViewModel>
@{
    ViewData["Title"] = "Repairs";
    var listState = ViewData["ListState"] as ListStateViewModel;
}

<section class="hero-panel">
    <p class="hero-kicker">Repair queue</p>
    <h1 class="hero-title">Repairs</h1>
    <p class="hero-subtitle">A high-clarity work queue that surfaces repair status, owner, guitar, and technician assignments without a plain table layout.</p>
    <div class="hero-actions">
        <a class="action-link primary" asp-action="Create">Create new repair</a>
        <a class="action-link secondary" asp-controller="Home" asp-action="Index">Back to dashboard</a>
    </div>
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_ListControls", listState)
}

<section class="card-grid">
    @foreach (var repair in Model)
    {
        var item = repair;
        var repairModel = item.Repair;
        var cardClass = item.MissingSkillCoverage
            ? "queue-card repair-card repair-card--impossible"
            : item.NeedsTechnician
                ? "queue-card repair-card repair-card--needs-tech"
                : "queue-card repair-card";
        var chipClass = repairModel.StatusNaloga?.Id switch
        {
            4 => "success",
            5 => "danger",
            3 => "warning",
            2 => "info",
            _ => "info"
        };

        <article class="@cardClass" data-delete-card data-repair-alert="@(item.MissingSkillCoverage ? "impossible" : item.NeedsTechnician ? "needs-tech" : "normal")">
            <div class="queue-head">
                <div>
                    <p class="section-label">@repairModel.VrstaPopravka?.Naziv</p>
                    <h2 class="queue-title">@repairModel.Stranka.Ime @repairModel.Stranka.Prezime</h2>
                    <p class="queue-subtitle">@repairModel.OpisKvara</p>
                    @if (item.MissingSkillCoverage)
                    {
                        <p class="repair-alert-copy">No technician has the required skill. Add or update technician skills before this can move forward.</p>
                    }
                    else if (item.NeedsTechnician)
                    {
                        <p class="repair-warning-copy">Qualified technician exists. Assign one to start this repair.</p>
                    }
                </div>
                <span class="status-chip @chipClass">@repairModel.StatusNaloga?.Naziv</span>
            </div>

            <div class="queue-line">
                <span><strong>Guitar:</strong> @repairModel.Gitara.Marka?.Naziv @repairModel.Gitara.SerijskiBroj</span>
                <span><strong>Technician:</strong> @(repairModel.Tehnicar != null ? repairModel.Tehnicar.Ime + " " + repairModel.Tehnicar.Prezime : "Unassigned")</span>
                <span><strong>Opened:</strong> <span data-gc-date-display="@repairModel.DatumOtvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@repairModel.DatumOtvaranja.ToString("dd MMM yyyy")</span></span>
                <span><strong>Planned close:</strong> <span data-gc-date-display="@repairModel.DatumZatvaranja.ToString("yyyy-MM-ddTHH:mm:ss")">@repairModel.DatumZatvaranja.ToString("dd MMM yyyy")</span></span>
            </div>

            <div class="queue-footer">
                <a class="action-btn" asp-action="Details" asp-route-id="@repairModel.Id">View repair details</a>
                <a class="action-btn secondary repair-edit-action" asp-action="Edit" asp-route-id="@repairModel.Id">Edit repair</a>
                <form asp-action="Delete" asp-route-id="@repairModel.Id" method="post" data-delete-form data-delete-label="repair #@repairModel.Id">
                    @Html.AntiForgeryToken()
                    <button class="action-btn danger" type="submit">Delete</button>
                </form>
            </div>
        </article>
    }
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_LoadMore", listState)
}

@section Scripts {
    <script src="~/js/gc-repair-alerts.js" asp-append-version="true"></script>
}

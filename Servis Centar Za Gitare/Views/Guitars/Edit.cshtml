@model Servis_Centar_Za_Gitare.models.Gitara

@{
    ViewData["Title"] = "Edit Guitar";
    var tipoviGitare = ViewData["TipoviGitare"] as SelectList;
    var kupci = ViewData["Kupci"] as SelectList;
}

<h2 class="section-title">Edit Guitar</h2>

<form asp-action="Edit" method="post" class="gc-form" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="gc-card--form">
    <div class="form-group gc-form-group">
        <label asp-for="SerijskiBroj" class="gc-label">Serial Number</label>
        <input asp-for="SerijskiBroj" class="form-control gc-input" aria-describedby="SerijskiBroj-error" />
        <span asp-validation-for="SerijskiBroj" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    @await Html.PartialAsync("_AutocompleteCombo", new AutocompleteComboViewModel(nameof(Model.MarkaId), "Brand", Url.Action("AutocompleteBrands", "Guitars")!, Model.MarkaId > 0 ? Model.MarkaId : null, ViewData["SelectedBrandText"]?.ToString(), "MarkaId-error") { Placeholder = "Search brand..." })
    <div class="form-group gc-form-group">
        <label asp-for="BrojZica" class="gc-label">Number of Strings</label>
        <input asp-for="BrojZica" class="form-control gc-input" aria-describedby="BrojZica-error" />
        <span asp-validation-for="BrojZica" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="form-group gc-form-group">
        <label asp-for="TipGitareId" class="gc-label">Guitar Type</label>
        <div class="gc-select">
            <select asp-for="TipGitareId" class="form-control gc-input" asp-items="tipoviGitare" data-gc-select="true" aria-describedby="TipGitareId-error"></select>
        </div>
        <span asp-validation-for="TipGitareId" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel(nameof(Model.DatumZaprimanja), "Received Date", Model.DatumZaprimanja, maxFutureDays: 1, maxFutureMessage: "Received date cannot be more than one day in the future."))
    <div class="form-group gc-form-group">
        <label asp-for="KupacId" class="gc-label">Owner</label>
        <div class="gc-select">
            <select asp-for="KupacId" class="form-control gc-input" asp-items="kupci" data-gc-select="true" aria-describedby="KupacId-error"></select>
        </div>
        <span asp-validation-for="KupacId" class="invalid-feedback" role="alert" aria-live="polite"></span>
    </div>
    <div class="gc-actions">
        <button type="submit" class="btn gc-btn-primary">Save</button>
        <a asp-action="Index" class="btn gc-btn-secondary">Cancel</a>
    </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model IEnumerable<Gitara>
@{
    ViewData["Title"] = "Guitars";
    var repairCounts = ViewData["GuitarRepairCounts"] as IDictionary<long, int> ?? new Dictionary<long, int>();
    var listState = ViewData["ListState"] as ListStateViewModel;
}

<section class="hero-panel">
    <p class="hero-kicker">Instrument inventory</p>
    <h1 class="hero-title">Guitars</h1>
    <p class="hero-subtitle">A curated instrument index with owner context, intake information, and elegant card-based browsing.</p>
    <div class="hero-actions">
        <a class="action-link primary" asp-action="Create">Add guitar</a>
    </div>
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_ListControls", listState)
}

<section class="entity-grid">
    @foreach (var guitar in Model)
    {
        var repairCount = repairCounts.TryGetValue(guitar.Id, out var repairs) ? repairs : 0;
        var canDelete = repairCount == 0;
        var deleteTitle = canDelete
            ? "Delete guitar"
            : "Guitar cannot be deleted while it has repair orders.";

        <article class="entity-card" data-delete-card>
            <div class="entity-head">
                <div>
                        <p class="section-label">@guitar.Marka?.Naziv</p>
                            <h2 class="entity-title">@guitar.SerijskiBroj</h2>
                            <p class="entity-subtitle">@guitar.TipGitare?.Naziv</p>
                </div>
                <span class="status-chip info">@guitar.BrojZica strings</span>
            </div>

            <div class="entity-body">
                <div class="badge-row">
                    <span class="info-chip">Owner @(guitar.Kupac != null ? guitar.Kupac.Ime + " " + guitar.Kupac.Prezime : "Unknown")</span>
                    <span class="info-chip" data-gc-date-display="@guitar.DatumZaprimanja.ToString("yyyy-MM-ddTHH:mm:ss")">@guitar.DatumZaprimanja.ToString("dd MMM yyyy")</span>
                </div>
                <div class="queue-footer">
                    <a class="action-btn" asp-action="Details" asp-route-id="@guitar.Id">View guitar details</a>
                    <a class="action-btn secondary" asp-action="Edit" asp-route-id="@guitar.Id">Edit guitar</a>
                    <form asp-action="Delete" asp-route-id="@guitar.Id" method="post" data-delete-form data-delete-label="@guitar.SerijskiBroj">
                        @Html.AntiForgeryToken()
                        <button class="action-btn danger" type="submit" title="@deleteTitle" @(canDelete ? null : "disabled")>Delete</button>
                    </form>
                </div>
            </div>
        </article>
    }
</section>

@if (listState != null)
{
    @await Html.PartialAsync("_LoadMore", listState)
}

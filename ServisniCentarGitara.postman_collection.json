  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const rawIdentityCookie = pm.collectionVariables.get(\"identityCookie\") || pm.variables.get(\"identityCookie\") || \"\";",
          "const identityCookie = rawIdentityCookie.replace(/^\\.AspNetCore\\.Identity\\.Application=/, \"\").trim();",
          "if (identityCookie && !identityCookie.includes(\"paste-aspnetcore-identity-cookie-value-here\")) {",
          "    pm.request.headers.upsert({",
          "        key: \"Cookie\",",
          "        value: \".AspNetCore.Identity.Application=\" + identityCookie",
          "    });",
          "} else {",
          "    pm.request.headers.remove(\"Cookie\");",
          "    console.warn(\"Set collection variable identityCookie CURRENT VALUE to your .AspNetCore.Identity.Application cookie value.\");",
          "}"
        ]
      }
    }
